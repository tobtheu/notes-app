{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "enables the default permissions for mobile (iOS/Android)",
  "platforms": ["iOS", "android"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "dialog:default",
    "process:default",
    "store:default",
    "core:window:allow-close",
    "shell:allow-open"
  ]
}
