# ============================================================
# Lama Notes — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ---- Supabase -----------------------------------------------
# Found in: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Electric -----------------------------------------------
# URL to your self-hosted Electric service (docker-compose.yml)
# In development: http://localhost:5133
# In production:  https://electric.yourdomain.com
VITE_ELECTRIC_URL=http://localhost:5133

# ---- Docker Compose (Electric service) ----------------------
# Direct Postgres connection from Supabase:
# Supabase → Project Settings → Database → Session Pooler (direct)
ELECTRIC_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Generate with: openssl rand -hex 32
ELECTRIC_SECRET_KEY_BASE=your-secret-key-base-here

# Supabase JWT Secret:
# Supabase → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
